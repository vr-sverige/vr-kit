            "type": "component",
            "sourceCode": "import { Meta, StoryObj, moduleMetadata } from '@storybook/angular';\r\nimport { MatCardModule } from '@angular/material/card';\r\nimport { MatButtonModule } from '@angular/material/button';\r\nimport { Component } from '@angular/core';\r\n\r\n@Component({\r\n  selector: 'storybook-material-card',\r\n  template: `\r\n    <mat-card>\r\n      <mat-card-header>\r\n        <mat-card-title>Material Card</mat-card-title>\r\n        <mat-card-subtitle>With Angular Material styling</mat-card-subtitle>\r\n      </mat-card-header>\r\n      <mat-card-content>\r\n        <p>This is a Material card with a primary button.</p>\r\n      </mat-card-content>\r\n      <mat-card-actions>\r\n        <button mat-raised-button color=\"primary\">Primary Action</button>\r\n      </mat-card-actions>\r\n    </mat-card>\r\n  `,\r\n  standalone: true,\r\n  imports: [MatCardModule, MatButtonModule],\r\n})\r\nclass StorybookMaterialCardComponent {}\r\n\r\nexport default {\r\n  title: 'Material/Card',\r\n  component: StorybookMaterialCardComponent,\r\n} as Meta<StorybookMaterialCardComponent>;\r\n\r\ntype Story = StoryObj<StorybookMaterialCardComponent>;\r\n\r\nexport const Primary: Story = {};\r\n",
